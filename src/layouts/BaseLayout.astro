---
import '@fontsource-variable/schibsted-grotesk';
import '@fontsource-variable/newsreader';
import '../styles/global.css';
import { site } from '../data/site';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
  noindex?: boolean;
}

const {
  title = `${site.name} — Fassaden, Boden, Maler & Gipser in Zürich`,
  description = site.description,
  pathname = '/',
  noindex = false,
} = Astro.props;

const canonical = new URL(pathname, site.url).toString();
const ogImage = new URL('/og-image.svg', site.url).toString();

const localBusinessJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'GeneralContractor',
  '@id': `${site.url}/#business`,
  name: site.name,
  legalName: site.legalName,
  url: site.url,
  description: site.description,
  telephone: site.contact.phones[0].tel,
  email: site.contact.email,
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.contact.address.street,
    addressLocality: site.contact.address.city,
    postalCode: site.contact.address.postal,
    addressCountry: site.contact.address.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: site.contact.address.lat,
    longitude: site.contact.address.lng,
  },
  areaServed: [
    { '@type': 'City', name: 'Zürich' },
    { '@type': 'AdministrativeArea', name: 'Kanton Zürich' },
  ],
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '07:00',
      closes: '18:00',
    },
  ],
  makesOffer: site.services.map((s) => ({
    '@type': 'Offer',
    itemOffered: { '@type': 'Service', name: s.title, description: s.blurb },
  })),
  knowsAbout: [
    'Fassadenisolation',
    'Bodenisolation',
    'Wärmedämmverbundsysteme',
    'Malerarbeiten',
    'Gipserarbeiten',
    'Generalunternehmung',
    'Umbau',
    'Neubau',
  ],
};
---

<!doctype html>
<html lang="de-CH">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#E8DDC8" />
    <meta name="color-scheme" content="light" />
    <meta name="format-detection" content="telephone=yes" />

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.legalName} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="de_CH" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Geo -->
    <meta name="geo.region" content="CH-ZH" />
    <meta name="geo.placename" content="Zürich" />
    <meta name="geo.position" content={`${site.contact.address.lat};${site.contact.address.lng}`} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessJsonLd)} />

    <!-- Console credits -->
    <script is:inline>
      (function () {
        var bar = 'background:#2D2A26; color:#F5F1EA; font:600 13px ui-sans-serif,system-ui,sans-serif; line-height:1.9; padding:14px 22px;';
        var dim = 'color:#6B6660; font:12px ui-sans-serif,system-ui,sans-serif;';
        var label = 'color:#B9651F; font:600 12px ui-sans-serif,system-ui,sans-serif; letter-spacing:0.18em; text-transform:uppercase;';
        console.log(
          '%c\n   D F   I S O L A T I O N E N\n   ────────────────────────────────\n   Handwerk seit über 15 Jahren\n',
          bar
        );
        console.log('%cWebsite von', label);
        console.log('Miró Maximilian Waltisberg');
        console.log('https://mirowaltisberg.ch');
        console.log('m.waltisberg@qero.ch');
        console.log('+41 76 703 77 00');
        console.log('%c© ' + new Date().getFullYear() + ' — Mit Sorgfalt gebaut.', dim);
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Zum Inhalt springen</a>
    <slot />
    <Analytics />
  </body>
</html>
