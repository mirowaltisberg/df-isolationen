---
import Logo from './Logo.astro';
import { site } from '../data/site';
const phone = site.contact.phones[0];
---
<header class="header">
  <div class="header__inner">
    <Logo />

    <nav class="header__nav" aria-label="Hauptnavigation">
      <a href="#leistungen">Leistungen</a>
      <a href="#ueber-uns">Über uns</a>
      <a href="#prozess">Ablauf</a>
      <a href="#kontakt">Kontakt</a>
    </nav>

    <a class="header__cta" href={`tel:${phone.tel}`} aria-label={`Anrufen: ${phone.display}`}>
      <svg class="header__cta-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      <span class="header__cta-num tnum">{phone.display}</span>
    </a>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--c-cream) 85%, transparent);
    -webkit-backdrop-filter: saturate(140%) blur(14px);
    backdrop-filter: saturate(140%) blur(14px);
    border-bottom: 1px solid var(--c-line);
  }

  .header__inner {
    width: 100%;
    max-width: var(--container);
    margin: 0 auto;
    padding: 14px var(--gutter);
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--s-3);
  }

  .header__nav {
    display: none;
    grid-column: 2;
    justify-self: center;
    gap: clamp(20px, 3vw, 40px);
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--c-anthracite-soft);
  }

  .header__nav a {
    position: relative;
    padding: 8px 0;
  }
  .header__nav a::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 2px;
    height: 1px;
    background: var(--c-terracotta);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--t-fast) var(--ease-out);
  }
  .header__nav a:hover { color: var(--c-anthracite); }
  .header__nav a:hover::after { transform: scaleX(1); }

  .header__cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 18px;
    background: var(--c-terracotta);
    color: var(--c-cream);
    border-radius: 0;
    line-height: 1;
    min-height: 44px;
    transition: background var(--t-fast) var(--ease-out);
  }
  .header__cta:hover {
    background: var(--c-anthracite);
    color: var(--c-cream);
  }

  .header__cta-icon {
    flex-shrink: 0;
    color: currentColor;
  }

  .header__cta-num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: -0.005em;
    color: currentColor;
  }

  @media (max-width: 360px) {
    .header__cta { padding: 10px 14px; gap: 8px; }
    .header__cta-num { font-size: 0.875rem; }
  }

  @media (min-width: 920px) {
    .header__nav { display: inline-flex; }
  }
</style>
