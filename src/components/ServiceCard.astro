---
import { Image } from 'astro:assets';

interface Props {
  service: {
    slug: string;
    number: string;
    title: string;
    blurb: string;
    details: string[];
    image: string;
  };
}
const { service } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/*.{jpg,jpeg,png,webp}',
  { eager: true }
);
const img = images[`/src/assets/images/${service.image}.jpg`]?.default;
---
<article class="service" id={`leistung-${service.slug}`}>
  {img && (
    <div class="service__media">
      <Image
        src={img}
        alt={`${service.title} — Beispielbild`}
        widths={[320, 540, 800]}
        sizes="(min-width: 1024px) 33vw, (min-width: 720px) 50vw, 100vw"
        loading="lazy"
        format="webp"
        quality={80}
        class="service__img"
      />
    </div>
  )}
  <div class="service__body">
    <span class="service__num tnum" aria-hidden="true">{service.number} / 06</span>
    <h3 class="service__title">{service.title}</h3>
    <p class="service__blurb">{service.blurb}</p>
    <ul class="service__list">
      {service.details.map((d) => <li>{d}</li>)}
    </ul>
  </div>
</article>

<style>
  .service {
    padding: var(--s-5) var(--s-4) var(--s-6);
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
    background: var(--c-cream);
    transition: background var(--t-fast) var(--ease-out);
  }
  .service:hover {
    background: var(--c-cream-warm);
  }

  .service__media {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--c-sand);
  }
  .service__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 700ms var(--ease-out), filter 700ms var(--ease-out);
    filter: saturate(0.95);
  }
  .service:hover .service__img {
    transform: scale(1.04);
    filter: saturate(1.05);
  }

  .service__num {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.78rem;
    color: var(--c-terracotta);
    letter-spacing: 0.18em;
  }

  .service__title {
    font-family: var(--font-display);
    font-weight: 720;
    font-size: clamp(1.5rem, 2.4vw, 2rem);
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--c-anthracite);
    margin-top: var(--s-1);
  }

  .service__blurb {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--c-anthracite-soft);
    margin-top: var(--s-2);
    font-variation-settings: "opsz" 14;
  }

  .service__list {
    margin-top: var(--s-3);
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
    padding-top: var(--s-3);
    border-top: 1px solid var(--c-line);
  }
  .service__list li {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--c-anthracite-soft);
    padding-left: 20px;
    position: relative;
    line-height: 1.5;
  }
  .service__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 10px;
    height: 1px;
    background: var(--c-terracotta);
  }
</style>
